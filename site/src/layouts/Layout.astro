---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content="Ice availability schedule for curling at TeeLine" />
    <link rel="icon" type="image/svg+xml" href="/curling-schedule/favicon.svg" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --bg:                #eef2f7;
    --surface:           #ffffff;
    --text:              #1a202c;
    --text-muted:        #475569;
    --text-faint:        #94a3b8;
    --heading:           #1e3a5f;
    --accent:            #1e3a5f;
    --accent-hover:      #1d4ed8;
    --card-header-empty: #94a3b8;
    --chip-bg:           #dbeafe;
    --chip-text:         #1d4ed8;
    --no-ice:            #cbd5e1;
    --callout-bg:        #fefce8;
    --callout-border:    #fde047;
    --callout-accent:    #eab308;
    --callout-text:      #713f12;
    --shadow-sm:         rgba(0, 0, 0, 0.08);
    --shadow-md:         rgba(0, 0, 0, 0.12);
  }

  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    background-color: #9ec5e8;
    background-image:
      repeating-linear-gradient(
        60deg,
        transparent 0px, transparent 38px,
        rgba(255, 255, 255, 0.18) 38px, rgba(255, 255, 255, 0.18) 39px
      ),
      repeating-linear-gradient(
        -60deg,
        transparent 0px, transparent 38px,
        rgba(255, 255, 255, 0.18) 38px, rgba(255, 255, 255, 0.18) 39px
      ),
      linear-gradient(155deg, #cce3f7 0%, #8ab8e0 40%, #aed0ef 70%, #7aafd8 100%);
    color: var(--text);
    min-height: 100vh;
    padding: 2.5rem 1rem;
  }
</style>
